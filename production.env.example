# ───────────────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT VARIABLES
# Copy to production.env and fill in real values
# NEVER commit production.env to git!
# ───────────────────────────────────────────────────────────────────

# ── Django ──
DJANGO_SECRET_KEY=CHANGE-ME-run-python-c-import-secrets-secrets-token-urlsafe-50
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=false
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database ──
POSTGRES_USER=acme_prod
POSTGRES_PASSWORD=CHANGE-ME-strong-random-password
POSTGRES_DB=acme_saas
DATABASE_URL=postgresql://acme_prod:CHANGE-ME@postgres:5432/acme_saas

# ── Redis ──
REDIS_PASSWORD=CHANGE-ME-strong-random-password
REDIS_URL=redis://:CHANGE-ME@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE-ME@redis:6379/1

# ── MinIO / S3 ──
MINIO_ROOT_USER=CHANGE-ME-minio-admin
MINIO_ROOT_PASSWORD=CHANGE-ME-strong-random-password
S3_ACCESS_KEY=CHANGE-ME-minio-admin
S3_SECRET_KEY=CHANGE-ME-strong-random-password
S3_BUCKET_NAME=acme-media
S3_ENDPOINT_URL=http://minio:9000

# ── Stripe (optional — required for billing) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LIVE_MODE=false

# ── Email ──
# ANYMAIL_API_KEY=your-sendgrid-key
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587

# ── Sentry (optional) ──
# SENTRY_DSN=https://abc123@sentry.io/456

# ── Frontend ──
FRONTEND_URL=https://yourdomain.com
DOMAIN_BASE=yourdomain.com

# ── Modules ──
ENABLE_LMS=true
ENABLE_COMMUNITY=true
ENABLE_MCP=true
